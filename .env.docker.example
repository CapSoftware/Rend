# Docker Compose local stack. These values intentionally use Docker service
# names for container-to-container traffic.

REND_ENV=local
DATABASE_URL=postgres://rend:rend@postgres:5432/rend
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DATABASE=rend
CLICKHOUSE_USER=rend
CLICKHOUSE_PASSWORD=rend
OBJECT_STORE_HEALTH_URL=http://minio:9000/minio/health/ready
S3_ENDPOINT=http://minio:9000
S3_PRESIGN_ENDPOINT=http://127.0.0.1:9100
S3_REGION=us-east-1
S3_BUCKET=rend-local-media
S3_SOURCE_BUCKET=rend-local-source
AWS_ACCESS_KEY_ID=rend_minio
AWS_SECRET_ACCESS_KEY=rend_minio_password
REND_SELFHOST_UPLOADS_HOST=uploads.localhost
REND_SELFHOST_UPLOADS_URL=http://uploads.localhost:8080
# Optional pinned GHCR images. Leave blank to build the local checkout.
REND_API_IMAGE=
REND_WORKER_IMAGE=
REND_EDGE_IMAGE=
REND_SITE_IMAGE=

REND_API_BIND_ADDR=0.0.0.0:4000
REND_API_AUTO_MIGRATE=true
REND_API_INLINE_MEDIA_PROCESSING=false
REND_DEV_API_KEY=dev-api-key
REND_SITE_INTERNAL_TOKEN=local-site-internal-token
REND_BILLING_MODE=local
AUTUMN_SECRET_KEY=
AUTUMN_API_URL=
AUTUMN_API_VERSION=2.3.0
REND_BILLING_FEATURE_DELIVERY=delivery_seconds
REND_BILLING_FEATURE_STORAGE=storage_second_months
REND_AUTUMN_PRICE_DELIVERY_PER_MINUTE=0.001
REND_AUTUMN_PRICE_STORAGE_PER_MINUTE_MONTH=0.003
REND_BILLING_ENTITLEMENT_FAILURE_POLICY=fail_closed
REND_BILLING_DELIVERY_SYNC_LAG_SECS=60
REND_BILLING_DELIVERY_SYNC_MAX_WINDOW_SECS=3600
REND_BILLING_STORAGE_SYNC_LAG_SECS=60
REND_BILLING_STORAGE_SYNC_MAX_WINDOW_SECS=3600

REND_PLAYBACK_MODE=tigris
REND_TIGRIS_PLAYBACK_BASE_URL=http://127.0.0.1:4000
REND_PUBLIC_PLAYBACK_ENABLED=false
REND_PUBLIC_PLAYBACK_ALIAS_BUCKET=
REND_PUBLIC_PLAYBACK_ALIAS_PREFIX=v
REND_PUBLIC_PLAYBACK_ALIAS_ACL=public-read
# Edge playback is dormant by default. Set REND_PLAYBACK_MODE=edge to use these.
REND_PLAYBACK_BASE_URL=http://127.0.0.1:4100
REND_PLAYER_PLAYBACK_BASE_URL=
REND_PLAYER_EDGE_BASE_URLS=
REND_PLAYBACK_COOKIE_DOMAIN=
REND_MAX_UPLOAD_BYTES=536870912
REND_UPLOAD_SESSION_TTL_SECS=86400
REND_UPLOAD_SIGNED_URL_TTL_SECS=900
REND_ORGANIZATION_STORAGE_BYTES=268435456000
REND_PLATFORM_STORAGE_BYTES=5497558138880
REND_ORGANIZATION_VIDEO_LIMIT=50
REND_OPEN_UPLOAD_SESSIONS_PER_ORGANIZATION=10
REND_ACTIVE_MEDIA_JOBS_PER_ORGANIZATION=2
# Registry fanout is skipped unless REND_PLAYBACK_MODE=edge.
REND_EDGE_ACTIVE_HEARTBEAT_WINDOW_SECS=30
REND_EXPECTED_EDGES=local-edge-001=local=http://rend-edge:4100,rend-edge-us-east=us-east=http://rend-edge-us-east:4100,rend-edge-london=london=http://rend-edge-london:4100
REND_ALLOW_INSECURE_EDGE_URLS=false
# Fallback only in edge mode when no registered healthy edge is active.
REND_EDGE_WARM_URL=http://rend-edge:4100/internal/warm
REND_EDGE_PURGE_URL=http://rend-edge:4100/internal/purge
REND_INTERNAL_TELEMETRY_TOKEN=dev-internal-token
REND_PLAYBACK_TELEMETRY_MAX_BODY_BYTES=262144
REND_PLAYBACK_TELEMETRY_MAX_EVENTS_PER_BATCH=100
REND_PLAYBACK_ANALYTICS_DEFAULT_WINDOW_SECS=86400
REND_PLAYBACK_ANALYTICS_MAX_WINDOW_SECS=604800
REND_PLAYBACK_SIGNING_KEY_ID=local-dev-playback-key
REND_PLAYBACK_SIGNING_SECRET=local-dev-playback-signing-secret
REND_PLAYBACK_TOKEN_TTL_SECS=900
REND_PLAYBACK_BOOTSTRAP_PREFETCH_SEGMENTS=8
REND_FFMPEG_PATH=/usr/bin/ffmpeg
REND_FFPROBE_PATH=/usr/bin/ffprobe
REND_MEDIA_PROCESS_TIMEOUT_SECS=60
REND_MEDIA_JOB_MAX_ATTEMPTS=3
REND_MEDIA_WORKER_ID=docker-media-worker-001
REND_MEDIA_WORKER_POLL_INTERVAL_SECS=1
REND_MEDIA_JOB_LEASE_SECS=120
REND_MEDIA_JOB_HEARTBEAT_SECS=30
REND_MEDIA_SHUTDOWN_GRACE_SECS=90
REND_MEDIA_MONTHLY_BUDGET_MICROUSD=250000000
REND_MEDIA_MONTHLY_BASE_MICROUSD=154000000
REND_MEDIA_JOB_CEILING_MICROUSD=25000000
REND_MEDIA_TASK_MICROUSD_PER_SECOND=57
REND_MEDIA_BUDGET_SAFETY_FACTOR=2

REND_EDGE_BIND_ADDR=0.0.0.0:4100
REND_EDGE_ID=local-edge-001
REND_EDGE_REGION=local
REND_EDGE_BASE_URL=http://rend-edge:4100
REND_EDGE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REND_CONTROL_PLANE_URL=http://rend-api:4000
REND_EDGE_FAST_EMBED_CONTROL_PLANE_URL=http://rend-api:4000
REND_EDGE_FAST_EMBED_CACHE_TTL_SECS=60
REND_EDGE_HEARTBEAT_INTERVAL_SECS=2
REND_EDGE_CACHE_MAX_BYTES=
REND_EDGE_VALIDATE_CACHE_ORIGIN=true
REND_EDGE_ARTIFACT_RESOLUTION_CACHE_TTL_SECS=300
REND_EDGE_ARTIFACT_RESOLUTION_CACHE_MAX_ENTRIES=10000
REND_EDGE_ASSET_AVAILABILITY_CACHE_TTL_SECS=5
REND_EDGE_CACHE_MIN_FREE_BYTES=67108864
REND_EDGE_CACHE_DIR=/var/lib/rend/edge-cache
REND_EDGE_ORIGIN_HEALTH_URL=http://minio:9000/minio/health/ready
REND_EDGE_INTERNAL_TOKEN=dev-internal-token
REND_EDGE_WARM_MAX_ARTIFACTS=16
REND_EDGE_MAX_IN_FLIGHT_FILLS=64
REND_EDGE_MAX_ORIGIN_ARTIFACT_BYTES=536870912
REND_EDGE_TELEMETRY_ENABLED=true
REND_EDGE_TELEMETRY_INGEST_URL=http://rend-api:4000/internal/telemetry/playback
REND_EDGE_TELEMETRY_QUEUE_CAPACITY=1024
REND_EDGE_TELEMETRY_BATCH_SIZE=100
REND_EDGE_TELEMETRY_FLUSH_INTERVAL_SECS=2
REND_EDGE_TELEMETRY_REQUEST_TIMEOUT_SECS=2
REND_EDGE_TELEMETRY_SPOOL_DIR=/var/spool/rend/edge-telemetry
REND_EDGE_TELEMETRY_SPOOL_MAX_BYTES=10485760

REND_HTTP_TIMEOUT_SECS=120
