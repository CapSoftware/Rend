{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    ".env",
    ".env.*",
    "scripts/**"
  ],
  "globalEnv": [
    "CI",
    "NODE_ENV",
    "AUTH_SECRET",
    "AUTUMN_*",
    "AWS_*",
    "CLICKHOUSE_*",
    "DATABASE_URL",
    "OBJECT_STORE_*",
    "REDIS_URL",
    "BETTER_AUTH_*",
    "REND_*",
    "RESEND_*",
    "S3_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ],
      "env": [
        "NEXT_PUBLIC_*",
        "REND_API_BASE_URL",
        "REND_DEV_API_KEY",
        "REND_PLAYER_ALLOWED_PLAYBACK_BASE_URLS",
        "REND_PLAYER_PLAYBACK_BASE_URL",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NEXT_PUBLIC_*",
        "REND_API_BASE_URL",
        "REND_DEV_API_KEY",
        "REND_PLAYER_ALLOWED_PLAYBACK_BASE_URLS",
        "REND_PLAYER_PLAYBACK_BASE_URL",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN"
      ]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "env": [
        "NEXT_PUBLIC_*",
        "REND_API_BASE_URL",
        "REND_DEV_API_KEY",
        "REND_PLAYER_ALLOWED_PLAYBACK_BASE_URLS",
        "REND_PLAYER_PLAYBACK_BASE_URL",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
