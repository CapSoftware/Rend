{
  "name": "@rend-sdk/client",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Rend public API.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "homepage": "https://github.com/CapSoftware/Rend#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CapSoftware/Rend.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/CapSoftware/Rend/issues"
  },
  "keywords": [
    "rend",
    "video",
    "sdk",
    "api",
    "openapi"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck && npm run build",
    "test": "node --test --experimental-strip-types src/index.test.mts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
