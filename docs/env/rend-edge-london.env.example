# Production-style example for the london edge host.
# Copy to /etc/rend/rend-edge.env on that host and replace placeholders.

REND_ENV=production
S3_ENDPOINT=https://object-store.example.com
S3_REGION=eu-west-2
S3_BUCKET=rend-production
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

REND_EDGE_BIND_ADDR=0.0.0.0:4100
REND_EDGE_ID=rend-edge-london-001
REND_EDGE_REGION=london
REND_EDGE_BASE_URL=https://edge-london.example.com
REND_EXPECTED_EDGES=rend-edge-us-east-001=us-east=https://edge-us-east.example.com,rend-edge-london-001=london=https://edge-london.example.com
REND_ALLOW_INSECURE_EDGE_URLS=false
REND_CONTROL_PLANE_URL=https://api-internal.example.com
REND_EDGE_HEARTBEAT_INTERVAL_SECS=15
REND_EDGE_CACHE_MAX_BYTES=
REND_EDGE_CACHE_MIN_FREE_BYTES=67108864
REND_EDGE_CACHE_DIR=/var/lib/rend/edge-cache
REND_EDGE_ORIGIN_HEALTH_URL=https://object-store.example.com/health/ready
REND_EDGE_INTERNAL_TOKEN=replace-me
REND_EDGE_WARM_MAX_ARTIFACTS=16
REND_EDGE_MAX_IN_FLIGHT_FILLS=64
REND_EDGE_MAX_ORIGIN_ARTIFACT_BYTES=536870912

REND_EDGE_TELEMETRY_ENABLED=true
REND_EDGE_TELEMETRY_INGEST_URL=https://api-internal.example.com/internal/telemetry/playback
REND_INTERNAL_TELEMETRY_TOKEN=replace-me
REND_EDGE_TELEMETRY_QUEUE_CAPACITY=4096
REND_EDGE_TELEMETRY_BATCH_SIZE=100
REND_EDGE_TELEMETRY_FLUSH_INTERVAL_SECS=2
REND_EDGE_TELEMETRY_REQUEST_TIMEOUT_SECS=2
REND_EDGE_TELEMETRY_SPOOL_DIR=/var/spool/rend/edge-telemetry
REND_EDGE_TELEMETRY_SPOOL_MAX_BYTES=1073741824

REND_PLAYBACK_SIGNING_KEY_ID=prod-playback-key-001
REND_PLAYBACK_SIGNING_SECRET=replace-me
REND_HTTP_TIMEOUT_SECS=30

RUST_LOG=info
