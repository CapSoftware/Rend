# Production-style example for the control-plane API container.
# Copy to /etc/rend/rend-api.env on the control-plane host and replace every
# placeholder secret, hostname, and address before a trial.

REND_ENV=trial
DATABASE_URL=postgres://rend:replace-me@postgres.internal:5432/rend
REND_REDIS_URL=redis://redis.internal:6379
CLICKHOUSE_URL=https://clickhouse.internal:8123
CLICKHOUSE_DATABASE=rend
CLICKHOUSE_USER=rend
CLICKHOUSE_PASSWORD=replace-me

OBJECT_STORE_HEALTH_URL=https://object-store.example.com/health/ready
S3_ENDPOINT=https://object-store.example.com
S3_REGION=us-east-1
S3_BUCKET=rend-production
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

REND_API_BIND_ADDR=0.0.0.0:4000
REND_API_AUTO_MIGRATE=true
REND_API_INLINE_MEDIA_PROCESSING=false
REND_DEV_API_KEY=replace-me

REND_PLAYBACK_BASE_URL=https://edge-us-east.example.com
REND_MAX_UPLOAD_BYTES=536870912
# Registry fanout warms and purges every healthy edge in rend.edge_nodes.
REND_EDGE_ACTIVE_HEARTBEAT_WINDOW_SECS=120
REND_EXPECTED_EDGES=rend-edge-us-east-001=us-east=https://edge-us-east.example.com,rend-edge-london-001=london=https://edge-london.example.com
REND_ALLOW_INSECURE_EDGE_URLS=false
# Fallback only when no registered healthy edge is active.
REND_EDGE_WARM_URL=
REND_EDGE_PURGE_URL=
REND_EDGE_INTERNAL_TOKEN=replace-me
REND_INTERNAL_TELEMETRY_TOKEN=replace-me

REND_PLAYBACK_SIGNING_KEY_ID=prod-playback-key-001
REND_PLAYBACK_SIGNING_SECRET=replace-me
REND_PLAYBACK_TOKEN_TTL_SECS=900
REND_PLAYBACK_BOOTSTRAP_PREFETCH_SEGMENTS=2

REND_PLAYBACK_TELEMETRY_MAX_BODY_BYTES=262144
REND_PLAYBACK_TELEMETRY_MAX_EVENTS_PER_BATCH=100
REND_PLAYBACK_ANALYTICS_DEFAULT_WINDOW_SECS=86400
REND_PLAYBACK_ANALYTICS_MAX_WINDOW_SECS=604800

REND_EDGE_WARM_MAX_ARTIFACTS=4
REND_HTTP_TIMEOUT_SECS=120

REND_FFMPEG_PATH=/usr/bin/ffmpeg
REND_FFPROBE_PATH=/usr/bin/ffprobe
REND_MEDIA_PROCESS_TIMEOUT_SECS=60
REND_MEDIA_JOB_MAX_ATTEMPTS=3
REND_MEDIA_WORKER_POLL_INTERVAL_SECS=1
REND_MEDIA_JOB_LOCK_TIMEOUT_SECS=300

RUST_LOG=info
