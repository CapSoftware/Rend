# Production-profile root environment placeholders.
# Copy to .env.production.local for local production-targeted checks, or set these
# values in the hosting platform for real deployments. Replace every replace-me
# before running production validation without --allow-placeholders.

KV_REST_API_URL=https://redis.example.com
KV_REST_API_TOKEN=replace-me
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

REND_ENV=production
DATABASE_URL=postgres://rend:replace-me@postgres.internal:5432/rend
REDIS_URL=redis://redis.internal:6379
REND_REDIS_URL=redis://redis.internal:6379
CLICKHOUSE_URL=https://clickhouse.internal:8123
CLICKHOUSE_DATABASE=rend
CLICKHOUSE_USER=rend
CLICKHOUSE_PASSWORD=replace-me
OBJECT_STORE_HEALTH_URL=https://object-store.example.com/health/ready
S3_ENDPOINT=https://object-store.example.com
S3_REGION=us-east-1
S3_BUCKET=rend-production
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

REND_API_BASE_URL=https://api.example.com
REND_PUBLIC_API_BASE_URL=https://api.rend.so
REND_PUBLIC_SITE_BASE_URL=https://rend.so
REND_PLAYBACK_MODE=tigris
REND_TIGRIS_PLAYBACK_BASE_URL=https://api.rend.so
# Edge playback is dormant by default. Set REND_PLAYBACK_MODE=edge to use these.
REND_PLAYER_PLAYBACK_BASE_URL=
REND_PLAYER_EDGE_BASE_URLS=
REND_PLAYER_PLAYBACK_COOKIE_DOMAIN=rend.so
REND_API_CORS_ALLOWED_ORIGINS=https://rend.so,https://www.rend.so
REND_API_BIND_ADDR=0.0.0.0:4000
REND_API_AUTO_MIGRATE=false
REND_API_INLINE_MEDIA_PROCESSING=false
REND_SITE_INTERNAL_TOKEN=replace-me
REND_BILLING_MODE=autumn
AUTUMN_SECRET_KEY=replace-me
AUTUMN_API_URL=https://api.useautumn.com/v1
AUTUMN_API_VERSION=2.3.0
REND_ALLOW_EXTERNAL_TEST_CHECKOUT_REDIRECT=false
REND_BILLING_FEATURE_DELIVERY_720P=delivery_720p_seconds
REND_BILLING_FEATURE_DELIVERY_1080P=delivery_1080p_seconds
REND_BILLING_FEATURE_DELIVERY_2K=delivery_2k_seconds
REND_BILLING_FEATURE_DELIVERY_4K=delivery_4k_seconds
REND_BILLING_FEATURE_STORAGE_720P=storage_720p_second_months
REND_BILLING_FEATURE_STORAGE_1080P=storage_1080p_second_months
REND_BILLING_FEATURE_STORAGE_2K=storage_2k_second_months
REND_BILLING_FEATURE_STORAGE_4K=storage_4k_second_months
REND_AUTUMN_USAGE_CREDIT_FEATURE_ID=rend_usage_credits
REND_AUTUMN_PLAN_PAYG_ID=pay_as_you_go
REND_AUTUMN_PLAN_BUILDER_ID=builder
REND_AUTUMN_PLAN_SCALE_ID=scale
REND_AUTUMN_PLAN_ENTERPRISE_ID=enterprise
REND_AUTUMN_INTERNAL_DRY_RUN_PLAN_ID=internal_production_dry_run
REND_BILLING_ENTITLEMENT_FAILURE_POLICY=fail_closed
REND_BILLING_DELIVERY_SYNC_LAG_SECS=60
REND_BILLING_DELIVERY_SYNC_MAX_WINDOW_SECS=3600
REND_BILLING_STORAGE_SYNC_LAG_SECS=60
REND_BILLING_STORAGE_SYNC_MAX_WINDOW_SECS=3600

# Required only when running `bun run billing:setup-autumn -- --plans`.
# Values are dollar-credit costs per tracked unit; never guess these in code.
REND_AUTUMN_UNIT_COST_DELIVERY_720P=
REND_AUTUMN_UNIT_COST_DELIVERY_1080P=
REND_AUTUMN_UNIT_COST_DELIVERY_2K=
REND_AUTUMN_UNIT_COST_DELIVERY_4K=
REND_AUTUMN_UNIT_COST_STORAGE_720P=
REND_AUTUMN_UNIT_COST_STORAGE_1080P=
REND_AUTUMN_UNIT_COST_STORAGE_2K=
REND_AUTUMN_UNIT_COST_STORAGE_4K=
# Edge playback base used only when REND_PLAYBACK_MODE=edge.
REND_PLAYBACK_BASE_URL=https://edge-us-east.example.com
REND_MAX_UPLOAD_BYTES=536870912
REND_EDGE_ACTIVE_HEARTBEAT_WINDOW_SECS=120
REND_EXPECTED_EDGES=rend-edge-us-east-001=us-east=https://edge-us-east.example.com,rend-edge-london-001=london=https://edge-london.example.com
REND_ALLOW_INSECURE_EDGE_URLS=false
# Edge warm/purge fanout is skipped unless REND_PLAYBACK_MODE=edge.
REND_EDGE_WARM_URL=
REND_EDGE_PURGE_URL=
REND_EDGE_INTERNAL_TOKEN=replace-me
REND_INTERNAL_TELEMETRY_TOKEN=replace-me

REND_PLAYBACK_SIGNING_KEY_ID=prod-playback-key-001
REND_PLAYBACK_SIGNING_SECRET=replace-me
REND_PLAYBACK_TOKEN_TTL_SECS=900
REND_PLAYBACK_BOOTSTRAP_PREFETCH_SEGMENTS=8
REND_PLAYBACK_TELEMETRY_MAX_BODY_BYTES=262144
REND_PLAYBACK_TELEMETRY_MAX_EVENTS_PER_BATCH=100
REND_PLAYBACK_ANALYTICS_DEFAULT_WINDOW_SECS=86400
REND_PLAYBACK_ANALYTICS_MAX_WINDOW_SECS=604800

REND_FFMPEG_PATH=/usr/bin/ffmpeg
REND_FFPROBE_PATH=/usr/bin/ffprobe
REND_MEDIA_PROCESS_TIMEOUT_SECS=60
REND_MEDIA_JOB_MAX_ATTEMPTS=3
REND_MEDIA_WORKER_ID=rend-media-worker-001
REND_MEDIA_WORKER_POLL_INTERVAL_SECS=1
REND_MEDIA_JOB_LOCK_TIMEOUT_SECS=300

REND_EDGE_BIND_ADDR=0.0.0.0:4100
REND_EDGE_ID=rend-edge-us-east-001
REND_EDGE_REGION=us-east
REND_EDGE_BASE_URL=https://edge-us-east.example.com
REND_EDGE_CORS_ALLOWED_ORIGINS=https://rend.so,https://www.rend.so
REND_CONTROL_PLANE_URL=https://api-internal.example.com
REND_EDGE_HEARTBEAT_INTERVAL_SECS=15
REND_EDGE_CACHE_MAX_BYTES=
REND_EDGE_CACHE_MIN_FREE_BYTES=67108864
REND_EDGE_CACHE_DIR=/var/lib/rend/edge-cache
REND_EDGE_ORIGIN_HEALTH_URL=https://object-store.example.com/health/ready
REND_EDGE_WARM_MAX_ARTIFACTS=16
REND_EDGE_MAX_IN_FLIGHT_FILLS=64
REND_EDGE_MAX_ORIGIN_ARTIFACT_BYTES=536870912
REND_EDGE_TELEMETRY_ENABLED=true
REND_EDGE_TELEMETRY_INGEST_URL=https://api-internal.example.com/internal/telemetry/playback
REND_EDGE_TELEMETRY_QUEUE_CAPACITY=4096
REND_EDGE_TELEMETRY_BATCH_SIZE=100
REND_EDGE_TELEMETRY_FLUSH_INTERVAL_SECS=2
REND_EDGE_TELEMETRY_REQUEST_TIMEOUT_SECS=2
REND_EDGE_TELEMETRY_SPOOL_DIR=/var/spool/rend/edge-telemetry
REND_EDGE_TELEMETRY_SPOOL_MAX_BYTES=1073741824

BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=https://app.example.com
REND_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://rend.so
REND_SELF_SERVE_SIGNUP_ENABLED=true
RESEND_API_KEY=replace-me
REND_AUTH_EMAIL_FROM=Rend <auth@example.com>
REND_AUTH_EMAIL_DISABLED=false
REND_AUTH_OTP_PROBE_EMAIL=otp-health@example.com
REND_OPERATOR_EMAIL_ALLOWLIST=ops@example.com
REND_SITE_MAX_UPLOAD_BYTES=536870912
NEXT_PUBLIC_REND_APP_VERSION=production

REND_HTTP_TIMEOUT_SECS=120
RUST_LOG=info
