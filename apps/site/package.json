    "test": "node --test --experimental-strip-types lib/player-telemetry.test.mts lib/dashboard-auth.test.mts lib/auth.test.mts lib/billing.test.mts lib/api-keys.test.mts lib/operator.test.mts lib/readiness.test.mts lib/asset-api.test.mts lib/asset-routes.test.mts lib/dashboard-upload-token.test.mts lib/player-artifact-proxy.test.mts lib/player-edge-selection.test.mts lib/public-api-contract.test.mts lib/docs-content.test.mts app/api/player/artifact-route.test.mts app/api/player/telemetry/route.test.mts",
    "test:contract": "node --test --experimental-strip-types lib/public-api-contract.test.mts",
    "test:telemetry": "node --test --experimental-strip-types lib/player-telemetry.test.mts app/api/player/telemetry/route.test.mts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.18",
